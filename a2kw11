    Clear-Host
    $Gold = "Yellow"
    Write-Host @"
    █████╗ ███████╗████████╗███████╗██╗  ██╗
    ██╔══██╗╚══███╔╝╚══██╔══╝██╔════╝██║ ██╔╝
