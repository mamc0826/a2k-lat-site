    Write-Host "$BgBlack" -NoNewline
    Clear-Host
    Write-Host "`n $GoldTxt [1] English"
    Write-Host " [2] EspaГ±ol $Reset"
    $choice = Read-Host "`n AZTEK >"
    if ($choice -eq "2") { $Global:Lang = "ES" } else { $Global:Lang = "EN" }
}

