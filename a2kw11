# ============================================================================
# UI FUNCTIONS
# ============================================================================
function Set-Language {
    Clear-Host
    Write-Host " [1] English" -ForegroundColor Yellow
    Write-Host " [2] Español" -ForegroundColor Yellow
    $choice = Read-Host "`nSelect Language / Seleccione Idioma"
    if ($choice -eq "2") { $Global:Lang = "ES" } else { $Global:Lang = "EN" }
}

