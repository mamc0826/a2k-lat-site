    Write-Host " [2] " -NoNewline -ForegroundColor $Gold; Write-Host $L.Apps
    Write-Host " [3] " -NoNewline -ForegroundColor $Gold; Write-Host $L.Bloat
    Write-Host " [4] " -NoNewline -ForegroundColor $Gold; Write-Host $L.UI
    Write-Host " [5] " -NoNewline -ForegroundColor $Gold; Write-Host $L.Wall
    Write-Host " [6] " -NoNewline -ForegroundColor $Gold; Write-Host $L.Perf
    Write-Host " [7] " -NoNewline -ForegroundColor $Gold; Write-Host $L.Update
