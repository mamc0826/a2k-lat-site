function Show-Menu {
    Show-Header
    $L = $Text[$Global:Lang]
    $Gold = "$BgBlack$GoldTxt"
    
    Write-Host "$Gold [0] $WhiteTxt $($L.Rest)"
    Write-Host "$Gold [1] $WhiteTxt $($L.Full)"
    Write-Host "$Gold [2] $WhiteTxt $($L.Apps)"
    Write-Host "$Gold [3] $WhiteTxt $($L.Bloat)"
    Write-Host "$Gold [4] $WhiteTxt $($L.UI)"
