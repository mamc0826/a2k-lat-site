# ============================================================================
# LOGIC CORE FUNCTIONS
# ============================================================================
function Create-A2KRestorePoint {
    Write-Host "`n $GoldTxt $($Text[$Global:Lang].RestWait) $Reset"
    Enable-ComputerRestore -Drive "C:\" -ErrorAction SilentlyContinue
    Checkpoint-Computer -Description "AZTEK_Setup" -RestorePointType "MODIFY_SETTINGS" -ErrorAction SilentlyContinue
}

function Install-Software {
    Write-Host "`n $GoldTxt $($Text[$Global:Lang].Sync) $Reset"
    winget source update
    $Apps = @("Google.Chrome", "Mozilla.Firefox", "Brave.Brave", "7zip.7zip", "Notepad++.Notepad++", "VideoLAN.VLC", "SumatraPDF.SumatraPDF", "Python.Python.3.13", "Rufus.Rufus", "Daum.PotPlayer", "HandBrake.HandBrake", "Genymobile.scrcpy", "File-New-Project.EarTrumpet", "Klocman.BulkCrapUninstaller", "RevoUninstaller.RevoUninstaller", "AntibodySoftware.WizTree", "MiniTool.PartitionWizard.Free", "th-ch.YouTubeMusic", "Google.PlatformTools", "VMware.WorkstationPro", "GGPoker.GGPoker")
    foreach ($app in $Apps) {
        Write-Host " $GoldTxt >> $($Text[$Global:Lang].Summon) $WhiteTxt $app... $Reset"
        winget install --id $app --silent --accept-package-agreements --accept-source-agreements
    }
}

function Remove-Bloatware {
    Write-Host "`n $RedTxt [!] PURGING SYSTEMS... $Reset"
    $Bloat = @("Microsoft.BingNews", "Microsoft.BingWeather", "Microsoft.BingSearch", "MicrosoftTeams", "Microsoft.Teams", "Microsoft.Todos", "Microsoft.YourPhone", "Microsoft.GamingApp", "Microsoft.XboxApp", "Microsoft.MicrosoftSolitaireCollection", "Microsoft.MicrosoftOfficeHub")
    foreach ($pkg in $Bloat) { Get-AppxPackage -Name $pkg -AllUsers | Remove-AppxPackage -AllUsers -ErrorAction SilentlyContinue }
}

function Apply-Tweaks {
    Write-Host "`n $GoldTxt [!] CONFIGURING INTERFACE... $Reset"
    Stop-Process -Name explorer -Force -ErrorAction SilentlyContinue
    Start-Sleep -Seconds 1
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize" AppsUseLightTheme 0 -Force
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize" SystemUsesLightTheme 0 -Force
    $Classic = "HKCU:\Software\Classes\CLSID\{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}\InprocServer32"
    if (!(Test-Path $Classic)) { New-Item -Path $Classic -Force | Out-Null }
    Set-ItemProperty $Classic -Name "(Default)" -Value "" -Force
    $AdvPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced"
    $SearchPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Search"
    Set-ItemProperty -Path $SearchPath -Name "SearchboxTaskbarMode" -Value 0 -Force 
    Set-ItemProperty -Path $AdvPath -Name "TaskbarDa" -Value 0 -Force               
    Set-ItemProperty -Path $AdvPath -Name "TaskbarMn" -Value 0 -Force               
    Set-ItemProperty -Path $AdvPath -Name "HideFileExt" -Value 0 -Force             
    Set-ItemProperty -Path $AdvPath -Name "Hidden" -Value 1 -Force                  
    Start-Process explorer
}

function Set-A2KWallpapers {
    $WallDir = "$env:USERPROFILE\Pictures\a2k_walls"
    if (!(Test-Path $WallDir)) { New-Item -ItemType Directory -Path $WallDir -Force | Out-Null }
    $Url = "https://raw.githubusercontent.com/mamc0826/a2k-lat-site/main/wall1.jpg"
    $Dest = "$WallDir\wall1.jpg"
    curl.exe -L -s -o $Dest $Url
    if (Test-Path $Dest) {
        $Signature = 'using System.Runtime.InteropServices; public class NativeWallpaper { [DllImport("user32.dll")] public static extern bool SystemParametersInfo(int uAction, int uParam, string lpvParam, int fuWinIni); }'
        if (-not ([System.Management.Automation.PSTypeName]"NativeWallpaper").Type) { Add-Type $Signature }
        Set-ItemProperty "HKCU:\Control Panel\Desktop" WallpaperStyle 10
        [NativeWallpaper]::SystemParametersInfo(20, 0, $Dest, 3) | Out-Null
    }
}

# ============================================================================
# MAIN LOOP
# ============================================================================
Set-Language
do {
    Show-Menu
    $choice = Read-Host "`n $GoldTxt AZTEK > $Reset"
    switch ($choice) {
        '0' { Create-A2KRestorePoint; pause }
        '1' { Create-A2KRestorePoint; Install-Software; Remove-Bloatware; Apply-Tweaks; Set-A2KWallpapers; pause }
        '2' { Install-Software; pause }
        '3' { Remove-Bloatware; pause }
        '4' { Apply-Tweaks; pause }
        '5' { Set-A2KWallpapers; pause }
        '6' { powercfg /setactive 8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c; pause }
        '7' { winget upgrade --all; pause }
        '9' { Start-Process "https://yourwebsite.com"; pause } # Placeholder for your site
        '8' { break }
    }
} while ($choice -ne '8')
